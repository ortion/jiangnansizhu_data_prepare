{
  "$schema": "https://schema.tauri.app/config/2.10.1",
  "productName": "jianpu-annotator",
  "version": "1.0.0",
  "identifier": "com.jianpu.annotator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "简谱标注器 - 江南丝竹",
        "width": 1200,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
